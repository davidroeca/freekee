# ─────────────────────────────────────────────────────────────
# freekee .gitignore
# Rust workspace + Tauri 2 (desktop + iOS/Android) + Bun frontend
# ─────────────────────────────────────────────────────────────

# ── Rust ──────────────────────────────────────────────────────
target/
**/target/
**/*.rs.bk
*.pdb
Cargo.lock.bak

# Keep the workspace Cargo.lock checked in (we ship binaries).
# Uncomment if this repo only produces libraries:
# Cargo.lock

# rust-analyzer / IDE artifacts in target dirs
**/rust-project.json

# ── Fuzzing ───────────────────────────────────────────────────
fuzz/target/
fuzz/artifacts/
fuzz/coverage/
# Keep fuzz/corpus/ checked in (or via git-lfs); ignore generated crashes only.
fuzz/corpus/**/crash-*
fuzz/corpus/**/leak-*
fuzz/corpus/**/timeout-*

# ── Bun / Node (Tauri frontend) ───────────────────────────────
node_modules/
**/node_modules/

# Bun caches and logs
.bun/
bun-debug.log*

# Reject other JS package managers — pick one tool.
# These should never appear in the repo; ignored as a belt-and-suspenders.
package-lock.json
pnpm-lock.yaml
yarn.lock
.pnpm-store/
.pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
.yarnrc.yml.local

# Build outputs
dist/
dist-ssr/
build/
.vite/
.svelte-kit/
.solid/
.output/
*.local

# Vite / bundler caches
.cache/
.parcel-cache/
.turbo/

# ── Tauri ─────────────────────────────────────────────────────
# Generated mobile project scaffolding (regenerated by `tauri ios/android init`)
app/src-tauri/gen/
# If you customize the generated Xcode project (e.g., for AutoFill in v0.2),
# remove the line above and selectively un-ignore the customized files.

# Tauri build artifacts
app/src-tauri/target/
app/src-tauri/WixTools/
app/src-tauri/.tauri/

# Tauri signing keys — NEVER commit
*.tauri.key
*.tauri.pem
~/.tauri/

# ── iOS / Xcode ───────────────────────────────────────────────
**/*.xcodeproj/xcuserdata/
**/*.xcodeproj/project.xcworkspace/xcuserdata/
**/*.xcworkspace/xcuserdata/
**/*.xcodeproj/project.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist

# CocoaPods
Pods/
**/Pods/
*.xcworkspace
!default.xcworkspace

# Swift Package Manager
.build/
.swiftpm/
Package.resolved

# Provisioning / signing — NEVER commit
*.mobileprovision
*.provisionprofile
*.p12
*.p8
*.cer
*.certSigningRequest
ExportOptions.plist

# DerivedData
DerivedData/
**/DerivedData/

# ── Android ───────────────────────────────────────────────────
*.iml
.gradle/
**/.gradle/
local.properties
captures/
.externalNativeBuild/
.cxx/
android/app/release/
android/app/debug/

# Keystores — NEVER commit
*.jks
*.keystore
keystore.properties

# ── Secrets / environment ─────────────────────────────────────
.env
.env.*
!.env.example
*.env.local
secrets/
.secrets/

# Anything that looks like a real key
*.pem
*.key
!**/test-vectors/**/*.key
!**/fixtures/**/*.key
*.gpg
*.asc

# ── freekee-specific: never commit real vaults ────────────────
# Test fixtures live under explicit paths and are allowlisted below.
# Anything else that looks like a database is presumed real.
*.kdbx
*.kdb
!tests/roundtrip/fixtures/**/*.kdbx
!crates/*/tests/fixtures/**/*.kdbx

# Test fixture passwords are intentionally checked in. Make sure
# real passwords NEVER end up in these files.
!tests/roundtrip/fixtures/**/password.txt
!crates/*/tests/fixtures/**/password.txt

# Backup/conflict files generated by sync clients or `freekee rotate`
*.kdbx.bak
*.freekee-bak-*
*sync-conflict*

# ── Logs / coverage / profiling ───────────────────────────────
*.log
logs/
coverage/
*.profraw
*.profdata
tarpaulin-report.html
lcov.info

# Criterion benchmarks
**/criterion/

# Flamegraphs / perf
flamegraph.svg
perf.data*
*.dSYM/

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# direnv
.envrc
.direnv/

# Nix
result
result-*

# ── OS junk ───────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ── Misc build/tooling ────────────────────────────────────────
*.bak
*.tmp
*.orig
*.rej
.history/
.cargo/config.toml.local
